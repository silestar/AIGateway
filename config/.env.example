# AIGateway 环境变量模板
# 复制为 .env 后修改，.env 不会被 git 追踪

# 加密密钥（首次启动自动生成，勿随意更改否则已加密数据无法解密）
SECRET_KEY=

# 管理端认证 Token
AGW_SERVER_API_TOKEN=

# 数据库（覆盖 config.yaml）
# AGW_DB_TYPE=sqlite
# AGW_DB_PATH=data/agw.db

# Redis
# AGW_REDIS_ENABLED=false
# AGW_REDIS_HOST=127.0.0.1
# AGW_REDIS_PORT=6379
# AGW_REDIS_PASSWORD=

# 账号池参数（覆盖 config.yaml）
# AGW_ACCOUNT_MANAGER_AFFINITY_TTL=3600
# AGW_ACCOUNT_MANAGER_CONSECUTIVE_FAILURE_THRESHOLD=5
# AGW_ACCOUNT_MANAGER_MIN_DISABLE_DURATION=120
